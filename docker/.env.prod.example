# PostgreSQL
POSTGRES_DB=event_aggregator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<secure-password>

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:<secure-password>@postgres:5432/event_aggregator
REDIS_URL=redis://redis:6379/0
SECRET_KEY=<random-secret-at-least-32-chars>
ENVIRONMENT=production
LOG_LEVEL=INFO
CORS_ORIGINS=<your-domain>
DEFAULT_IMPORT_CATEGORY_ID=d25a71d1-9001-4e4c-926f-4fa2e5de013c
UPLOAD_DIR=/app/uploads
REDIS_HOST=redis

# Frontend (build-time ARG)
NEXT_PUBLIC_API_URL=https://<your-domain>/api/v1

# Nginx
NGINX_HOST=<your-domain>
